      "groupIds": [],
      "frameId": null,
      "index": "b4p",
      "roundness": null,
      "seed": 738280919,
      "version": 1009,
      "versionNonce": 1350352921,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770694166160,
      "link": null,
      "locked": false,
      "text": "B3: Open Connection\nB4: Execute Query:\nCUD trả về R -> Result set: là con trỏ tới list Data, mỗi đối\ntượng trong list là 1 dòng trong table có đặc tính là foward-\nonly\n",
      "fontSize": 24,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "B3: Open Connection\nB4: Execute Query:\nCUD trả về R -> Result set: là con trỏ tới list Data, mỗi đối tượng trong list là 1 dòng trong table có đặc tính là foward-only\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
