    {
      "id": "o-7lEXcDaqPODv5O0q8Cm",
      "type": "text",
      "x": 242.75592308315265,
      "y": 1708.078861863654,
      "width": 1440.5198033361867,
      "height": 435,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3m",
      "roundness": null,
      "seed": 576819981,
      "version": 1785,
      "versionNonce": 1962223193,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770690761092,
      "link": null,
      "locked": false,
      "text": "                                                    Request Parameter\n\n+ Parameter là cặp [name,value] được chuyển về phía server từ phía client thông qua request\n+Parameter có format là name=value. Format này được nhìn thấy ở phía client\n+ Nếu có nhiều hơn 1 parameter, các cặp parameter được phân cách bởi dấu &\n+Name của parameter được lấy từ name attribute của control, value của parameter được lấy từ value\nattribute của control\n+ control được chuyển thành parameter khi và chỉ khi nó được bao trong form và có submit button\n+ Paramter luôn là kiểu String, 1 chuỗi gồm nhiều parameter gọi là queryString\n+ ở phía server, parameter được truy cập theo name để lấy value\n+ Nếu Name ở phía client không tồn tại, value ở phía server là null\n+ Ở server, value của parameter là read-only",
      "fontSize": 29,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "                                                    Request Parameter\n\n+ Parameter là cặp [name,value] được chuyển về phía server từ phía client thông qua request\n+Parameter có format là name=value. Format này được nhìn thấy ở phía client\n+ Nếu có nhiều hơn 1 parameter, các cặp parameter được phân cách bởi dấu &\n+Name của parameter được lấy từ name attribute của control, value của parameter được lấy từ value attribute của control\n+ control được chuyển thành parameter khi và chỉ khi nó được bao trong form và có submit button\n+ Paramter luôn là kiểu String, 1 chuỗi gồm nhiều parameter gọi là queryString\n+ ở phía server, parameter được truy cập theo name để lấy value\n+ Nếu Name ở phía client không tồn tại, value ở phía server là null\n+ Ở server, value của parameter là read-only",
      "autoResize": false,
      "lineHeight": 1.25
    },
