    {
      "id": "5kAgCbgTgMSEVwWguSEOj",
      "type": "text",
      "x": 5701.714889869503,
      "y": 2148.3616859538006,
      "width": 1679.4983932059477,
      "height": 435,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4a",
      "roundness": null,
      "seed": 1571253145,
      "version": 4055,
      "versionNonce": 716290487,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770690552089,
      "link": null,
      "locked": false,
      "text": "+ who: container tạo ra servlet object\n+ when: servlet object được tạo ra khi ứng dụng được deploy\n+ when: servlet chỉ end khi ứng dụng bị undeploy hay servlet class reloaded hoặc server bị crashed\n- servlet có khả năng output HTML String vào responses object( chỉ biết đúng sai sau khi chạy và bất tiện để sữa sau\nkhi deploy)\n- servlet có 3 inprocess method:\n    + init(): thay cho default constructor: Hỗ trợ gán giá trị ban đầu cho servlet object, chỉ được gọi 1 lần ở lần\nrequest đầu tiên\n    +service(): được kích hoạt mỗi khi người dùng request\n        - method này có tên là do + HTTP Method(GET, POST, HEAD, OPTION, TRACE, PUT, DELETE)\n        - không thể chỉnh sửa bởi vì nó là signature của container\n    +destroy(): chỉ chạy 1 lần khi servlet object end(Bước 3 trên life cycle)",
      "fontSize": 29,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "+ who: container tạo ra servlet object\n+ when: servlet object được tạo ra khi ứng dụng được deploy\n+ when: servlet chỉ end khi ứng dụng bị undeploy hay servlet class reloaded hoặc server bị crashed\n- servlet có khả năng output HTML String vào responses object( chỉ biết đúng sai sau khi chạy và bất tiện để sữa sau khi deploy)\n- servlet có 3 inprocess method:\n    + init(): thay cho default constructor: Hỗ trợ gán giá trị ban đầu cho servlet object, chỉ được gọi 1 lần ở lần request đầu tiên\n    +service(): được kích hoạt mỗi khi người dùng request\n        - method này có tên là do + HTTP Method(GET, POST, HEAD, OPTION, TRACE, PUT, DELETE)\n        - không thể chỉnh sửa bởi vì nó là signature của container\n    +destroy(): chỉ chạy 1 lần khi servlet object end(Bước 3 trên life cycle)",
      "autoResize": false,
      "lineHeight": 1.25
    },
