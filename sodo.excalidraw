      "boundElements": [],
      "updated": 1770690552089,
      "link": null,
      "locked": false,
      "text": "+controller không xử lý vì không có CPU và không\ncó memory\n+controller đón nhận yêu cầu xử lý và forward\nsignal đến đối tượng xử lý\n+controller sử dụng công nghệ servlet\n+servlet là 1 java class",
      "fontSize": 29,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "+controller không xử lý vì không có CPU và không có memory\n+controller đón nhận yêu cầu xử lý và forward signal đến đối tượng xử lý\n+controller sử dụng công nghệ servlet\n+servlet là 1 java class",
      "autoResize": false,
      "lineHeight": 1.25
    },
