    {
      "id": "ZGInc5f-W0QRh21vAkMaj",
      "type": "text",
      "x": 1821.816399338185,
      "y": 2190.2440304515553,
      "width": 734.9581633344164,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fefffe",
      "fillStyle": "solid",
