    {
      "id": "0Lzcw4D--irhq5R5vie_z",
      "type": "text",
      "x": 1913.2411081535142,
      "y": 1196.639530811693,
      "width": 668.1358860560816,
      "height": 360,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fefffe",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b57",
      "roundness": null,
      "seed": 1272202041,
      "version": 1062,
      "versionNonce": 399451351,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770695238288,
      "link": null,
      "locked": false,
      "text": "- DTO là 1 java class implemented Serializable vì Object\nở phía server phải được chuyển đổi thành dạng\nbit/bytestream và ngược lại\n- Mỗi DTO mapping chính xác với 1 dòng ở table dưới DB\n- Ta phải khai báo không public tất cả thuộc tính ở DTO\nmapping với các cợt của 1 dòng trong table\n- Phải định nghĩa đầy đủ các getter, setter, properties\nđã được khai báo\n- Quy tắc đặt tên: tên table dưới DB, viết hoa chữ đầu\n+ DTO\n- Phải đặt trong package: tên table dưới DB, viết\nthường chữ đầu",
      "fontSize": 24,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- DTO là 1 java class implemented Serializable vì Object ở phía server phải được chuyển đổi thành dạng bit/bytestream và ngược lại\n- Mỗi DTO mapping chính xác với 1 dòng ở table dưới DB\n- Ta phải khai báo không public tất cả thuộc tính ở DTO mapping với các cợt của 1 dòng trong table\n- Phải định nghĩa đầy đủ các getter, setter, properties đã được khai báo\n- Quy tắc đặt tên: tên table dưới DB, viết hoa chữ đầu + DTO\n- Phải đặt trong package: tên table dưới DB, viết thường chữ đầu",
      "autoResize": false,
      "lineHeight": 1.25
    },
