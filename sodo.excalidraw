    {
      "id": "guSjKZcTS8qbqxjlXXJKG",
      "type": "text",
      "x": 3239.6649651243406,
      "y": 2279.1406733700096,
      "width": 876.6110495713674,
      "height": 326.25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4S",
      "roundness": null,
      "seed": 1551658380,
      "version": 951,
      "versionNonce": 431070967,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770690552089,
      "link": null,
      "locked": false,
      "text": "+ DAO là 1 object\n+ DAO cung cấp tất cả phương thức để truy cập database\n+ DAO bắt buộc phải implemented Serializable vì Object ở phía\nserver phải được chuyển đổi thành dạng bit/bytestream và\nngược lại\n+ DAO class phải được đặt tên theo quy tắc: lấy tên table\ndưới DB, chữ đầu viết hoa + DAO\n+ DAO class bược phải đặt trong package có tên table dưới\nDB chữ đầu viết thường",
      "fontSize": 29,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "+ DAO là 1 object\n+ DAO cung cấp tất cả phương thức để truy cập database\n+ DAO bắt buộc phải implemented Serializable vì Object ở phía server phải được chuyển đổi thành dạng bit/bytestream và ngược lại\n+ DAO class phải được đặt tên theo quy tắc: lấy tên table dưới DB, chữ đầu viết hoa + DAO\n+ DAO class bược phải đặt trong package có tên table dưới DB chữ đầu viết thường",
      "autoResize": false,
      "lineHeight": 1.25
    },
