      "versionNonce": 147941911,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770691266798,
      "link": null,
      "locked": false,
      "text": "B1: Create sql String: Khi viết lệnh SQL, mỗi lệnh SQL phải viết\ntrên 1 dòng, mỗi khi xuống dòng phải chèn thêm 1 khoảng trống\n\nB2:Load sql vào statement object\n",
      "fontSize": 24,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "B1: Create sql String: Khi viết lệnh SQL, mỗi lệnh SQL phải viết trên 1 dòng, mỗi khi xuống dòng phải chèn thêm 1 khoảng trống\n\nB2:Load sql vào statement object\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "6ngrZF7762S3P0feZe3x-",
      "type": "text",
      "x": 1814.6655161547383,
      "y": 2337.549992687019,
      "width": 376.10740321682187,
      "height": 210,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fefffe",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4m",
