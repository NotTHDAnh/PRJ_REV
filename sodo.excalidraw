    },
    {
      "id": "-0dzkuO5dpoLJQ5fGhfII",
      "type": "text",
      "x": 2649.938746423253,
      "y": 2220.4118458438115,
      "width": 516.1953098827695,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fefffe",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4u",
      "roundness": null,
      "seed": 389083255,
      "version": 1221,
      "versionNonce": 517032215,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770694525113,
      "link": null,
      "locked": false,
      "text": "B1: Load driver( driver là 1 danh sách liệt\nkê kiễu dữ liệu để chuyển đổi từ DBMS\nsang ngôn ngữ lập trình và ngyoc75 lại.\n- driver do DBMS tạo ra\n- các driver được quản lý bởi driver manager\n(là 1 đối tượng thực hiện chuyển đổi data\ntừ DMBS sang ngôn ngữ lập trình và ngược\nlại sử dụng driver)\n- viết code để add driver\n(ClassNOtFoundException xảy ra khi quên\nadd driver hoặc code chuỗi để add driver bị\nsai)\nB2: tạo connection string để connect\ndatabase)\n",
      "fontSize": 24,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "B1: Load driver( driver là 1 danh sách liệt kê kiễu dữ liệu để chuyển đổi từ DBMS sang ngôn ngữ lập trình và ngyoc75 lại.\n- driver do DBMS tạo ra\n- các driver được quản lý bởi driver manager (là 1 đối tượng thực hiện chuyển đổi data từ DMBS sang ngôn ngữ lập trình và ngược lại sử dụng driver)\n- viết code để add driver (ClassNOtFoundException xảy ra khi quên add driver hoặc code chuỗi để add driver bị sai)\nB2: tạo connection string để connect database)\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
